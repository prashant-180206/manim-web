@startuml Animat
!theme hacker
skinparam classAttributeIconSize 0
hide empty members

'========================================================
' SCENE
'========================================================

class Scene{
    +Selection selection

    +MobjectManager mobjects
    +AnimationSystem animations
    +TrackerSystem trackers

    +SceneEvents events

    --
    +selectMobject(id:String)
    +findMobject(id:String)
    +clearSelection()
}

Scene *-- Selection
Scene *-- MobjectManager
Scene *-- AnimationSystem
Scene *-- TrackerSystem
Scene *-- SceneEvents

class Selection{

    +Mobject activeMobject

    +Animation activeAnimation

    +String activeProperty

    --
    +select(Mobject)
    +clear()
}

class SceneEvents{

    +onSelectionChanged()

    +onMobjectAdded()
    +onMobjectDeleted()

    +onAnimationAdded()
    +onAnimationDeleted()

    +onTrackerAdded()
    +onTrackerDeleted()

    +onPropertyChanged()
}

'========================================================
' MOBJECTS
'========================================================

class MobjectManager{

    -Map<String,Mobject> objects

    --
    +add(Mobject)
    +remove(id:String)
    +find(id:String)
}

MobjectManager *-- Mobject

abstract class Mobject{

    +String id

    +String name

    +PropertyController<BaseProperty> propertyController

    +AnimationProvider animations

    --
    +render(ctx)
    +contains(x,y)
}

class Circle{

    +PropertyController<CircleProperty> propertyController
}

class Rectangle{

    +PropertyController<RectangleProperty> propertyController
}

class Polygon{

    +PropertyController<PolygonProperty> propertyController
}

class Curve{

    +PropertyController<CurveProperty> propertyController
}

class Line{

    +PropertyController<LineProperty> propertyController
}

class Text{

    +PropertyController<TextProperty> propertyController
}

Circle --|> Mobject
Rectangle --|> Mobject
Polygon --|> Mobject
Curve --|> Mobject
Line --|> Mobject
Text --|> Mobject

Mobject *-- PropertyController
Mobject *-- AnimationProvider

'========================================================
' PROPERTIES
'========================================================

class PropertyController<T>{

    +T properties

    --
    +getKeys()
}

interface BaseProperty{

    +opacity : Value<number>

    +position : Value<Vector>

    +scale : Value<Vector>

    +zindex : Value<number>

    +color : Value<string>
}

interface ShapeProperty{

    +strokeColor : Value<string>

    +strokeWidth : Value<number>
}

ShapeProperty --|> BaseProperty

interface CircleProperty{

    +radius : Value<number>
}

CircleProperty --|> ShapeProperty

interface RectangleProperty{

    +width : Value<number>

    +height : Value<number>
}

RectangleProperty --|> ShapeProperty

interface PolygonProperty{

    +points : Value<Vector[]>
}

PolygonProperty --|> ShapeProperty

interface CurveProperty{

    +points : Value<Vector[]>
}

CurveProperty --|> ShapeProperty

interface LineProperty{

    +start : Value<Vector>

    +end : Value<Vector>
}

LineProperty --|> ShapeProperty

interface TextProperty{

    +text : Value<string>

    +fontSize : Value<number>

    +fontFamily : Value<string>
}

TextProperty --|> BaseProperty

PropertyController --> BaseProperty

'========================================================
' VALUES
'========================================================

class Value<T>{

    +T value

    --
    +get()

    +set(value)
}

class Vector

Value --> Vector

'========================================================
' ANIMATION
'========================================================

class AnimationProvider{

    +supportedAnimations()

    +create(
        animationName,
        parameters
    )
}

class AnimationSystem{

    +List<Animation> animations

    +int currentIndex

    --
    +add(Animation)

    +remove(id)

    +play()

    +pause()

    +reverse()

    +seek(time)
}

Scene --> AnimationSystem

AnimationSystem *-- Animation

abstract class Animation{

    +String id

    +String name

    +Mobject target

    +String property

    +Value startValue

    +Value endValue

    +double duration

    +double progress

    +Easing easing

    --
    +play()

    +pause()

    +seek()
}

Animation --> Mobject
Animation --> Value

'========================================================
' TRACKERS
'========================================================

class TrackerSystem{

    -Map<String,Tracker> trackers

    -Map<String,Binding> bindings

    --
    +addTracker(Tracker)

    +removeTracker(id)

    +connect()

    +disconnect()
}

TrackerSystem *-- Tracker
TrackerSystem *-- Binding

class Tracker{

    +String id

    +String name

    +Value value

    --
    +setValue(Value)

    +getValue()
}

class Binding{
    +String id
    +Tracker tracker
    +Mobject target
    +String property
    --
    +transform(Value)

    +update()
}

Binding --> Tracker
Binding --> Mobject

@enduml